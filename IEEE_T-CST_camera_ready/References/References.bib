@article{WuCheng2025,
  author    = {Wu, Zhuohuan and Cheng, Sheng and Zhao, Pan and
               Gahlawat, Aditya and Ackerman, Kasey A. and
               Lakshmanan, Arun and Yang, Chengyu and Yu, Jiahao and
               Hovakimyan, Naira},
  title     = {{$\mathcal{L}_1$}Quad: {$\mathcal{L}_1$} Adaptive
               Augmentation of Geometric Control for Agile Quadrotors
               with Performance Guarantees},
  journal   = {IEEE Transactions on Control Systems Technology},
  year      = {2025},
  month     = mar,
  publisher = {IEEE},
  abstract  = {L1Quad is a control architecture that ensures
               uniformly bounded transient response of the quadrotor's uncertain
               dynamics on SE(3) by combining a geometric controller with an
               L1 adaptive controller. The architecture provides a theoretically
               justified framework for the design and analysis of quadrotor
               tracking controllers in the presence of nonlinear (time- and
               state-dependent) uncertainties on both translational and
               rotational dynamics. Performance is validated through extensive
               hardware experiments for eleven types of uncertainties across
               various trajectories, demonstrating consistently small tracking
               errors and significant outperformance of existing controllers.}
}

@article{SharmaSundaram2023,
  author    = {Sharma, Manmohan and Sundaram, Suresh},
  title     = {A geometric control approach for multi-{UAV} cooperative
               payload transfer},
  journal   = {Nonlinear Dynamics},
  year      = {2023},
  month     = jun,
  publisher = {Springer},
  abstract  = {A geometric control approach is developed for
               cooperative payload transfer by multiple UAVs. The method operates
               on the product configuration manifold and delivers tracking
               convergence guarantees under rigid-formation kinematics.}
}

@inproceedings{LiLoianno2023,
  author    = {Li, Guanrui and Loianno, Giuseppe},
  title     = {Nonlinear Model Predictive Control for Cooperative
               Transportation and Manipulation of Cable Suspended
               Payloads with Multiple Quadrotors},
  booktitle = {2023 {IEEE/RSJ} International Conference on Intelligent
               Robots and Systems ({IROS})},
  year      = {2023},
  month     = oct,
  publisher = {IEEE},
  abstract  = {A nonlinear MPC method enables a team of quadrotors to
               manipulate a rigid-body payload in all 6 DoF via suspended
               cables. The receding-horizon optimization exploits mechanical
               redundancies for inter-robot separation and obstacle avoidance
               while respecting payload dynamics and actuator constraints.
               A lightweight payload-state parametrisation on SE(3) enables
               real-time feasibility, validated through simulation and
               real-world experiments.}
}

@inproceedings{PallarLi2025,
  author    = {Pallar, Arpan and Li, Guanrui and Sarvaiya, Mrunal and
               Loianno, Giuseppe},
  title     = {Optimal Trajectory Planning for Cooperative Manipulation
               with Multiple Quadrotors Using Control Barrier Functions},
  booktitle = {2025 {IEEE} International Conference on Robotics and
               Automation ({ICRA})},
  year      = {2025},
  month     = may,
  publisher = {IEEE},
  abstract  = {A trajectory planning algorithm for cooperative
               manipulation with multiple quadrotors is presented, using
               control barrier functions to enforce inter-robot safety
               constraints and actuator limits. The approach is accepted at
               ICRA 2025.}
}

@article{SuBhowmick2023,
  author    = {Su, Yu-Hsiang and Bhowmick, Parijat and Lanzon, Alexander},
  title     = {A robust adaptive formation control methodology for
               networked multi-{UAV} systems with applications to
               cooperative payload transportation},
  journal   = {Control Engineering Practice},
  year      = {2023},
  month     = sep,
  publisher = {Elsevier},
  abstract  = {A robust adaptive formation control framework for
               networked multi-UAV systems is developed with explicit
               applications to cooperative payload transportation. The approach
               compensates parametric uncertainty across arbitrary directed
               communication topologies while maintaining bounded tracking errors
               under persistent disturbances.}
}

@article{LiuSuspensionFailure2021,
  title    = {Fault-tolerant control for the multi-quadrotors cooperative transportation under suspension failures},
  journal  = {Aerospace Science and Technology},
  volume   = {119},
  pages    = {107139},
  year     = {2021},
  issn     = {1270-9638},
  author   = {Xiao Liang and Zikang Su and Wenzhe Zhou and Guanglei Meng and Linlin Zhu},
  keywords = {Multiple quadrotors, Payload transportation, Trajectory control, Fault-tolerant, Disturbance observer},
  abstract = {This paper focuses on the fault-tolerant control of the multi-quadrotors cooperative payload transportation under suspension failures. A dynamic load reassignment and control strategy is proposed for the cooperative quadrotors by incorporating the high-order sliding mode disturbance observer into a dynamic surface control-based backstepping design. The dynamics of the cable-suspended payload transportation with multiple quadrotors are formulated. The unmeasurable suspension cable tensions, which will greatly impact the quadrotors' dynamics and stability, are respectively viewed as one part of the lumped disturbance and estimated by the super-twisting sliding mode-based finite-time disturbance observers. With the estimated disturbance compensation, the dynamic surface control laws are established for the cooperative quadrotors. Moreover, to guarantee the fault-tolerant control under suspension cable broken, a dynamic load assignment strategy is proposed to stably recover the cooperative load transportation. Finally, the stability of tethered quadrotors' flight control systems is analyzed. The simulation results show the effectiveness of the proposed algorithm under suspension failures.}
}

@inproceedings{GassnerPassiveForce2017,
  author    = {Tagliabue, Andrea and Kamel, Mina and Verling, Sebastian and Siegwart, Roland and Nieto, Juan},
  booktitle = {2017 IEEE International Conference on Robotics and Automation (ICRA)},
  title     = {Collaborative transportation using MAVs via passive force control},
  year      = {2017},
  volume    = {},
  number    = {},
  pages     = {5766-5773},
  abstract  = {This paper shows a strategy based on passive force control for collaborative object transportation using Micro Aerial Vehicles (MAVs), focusing on the transportation of a bulky object by two hexacopters. The goal is to develop a robust approach which does not rely on: (a) communication links between the MAVs, (b) the knowledge of the payload shape and (c) the position of grasping point. The proposed approach is based on the master-slave paradigm, in which the slave agent guarantees compliance to the external force applied by the master to the payload via an admittance controller. The external force acting on the slave is estimated using a non-linear estimator based on the Unscented Kalman Filter (UKF) from the information provided by a Visual-Inertial (VI) navigation system. Experimental results (online video [1]) demonstrate the performance of the force estimator and show the collaborative transportation of a 1.2 m long object.},
  keywords  = {Force;Payloads;Torque;Transportation;Collaboration;Quaternions;Admittance},
  issn      = {},
  month     = {May}
}

@inproceedings{NoCommTransport2021,
  author    = {Wu, Pin-Xian and Hung, Hsin-Ai and Yang, Cheng-Cheng and Cheng, Teng-Hu},
  booktitle = {2020 American Control Conference (ACC)},
  title     = {Cooperative Transportation of Drones without Inter-Agent Communication},
  year      = {2020},
  volume    = {},
  number    = {},
  pages     = {677-682},
  abstract  = {A control strategy for a leader-follower system without inter-agent communication is developed for cooperative transportation in this work. Two cascaded UKFs (unscented Kalman filters) are developed to estimate the external force of the leader as to eliminate the need of force sensors. Compared to most existing results, performance of the developed force estimators is invariant to lighting conditions since the developed UKFs do not require measurement from vision systems. To enhance robustness of the control scheme, a switching controller along with a triggering condition is developed for the follower, so that the impact to the performance of the closed-loop system caused by the disturbances can be minimized. Experiments are conducted to evaluate the control performance. Additionally, interesting phenomena are observed from the experiments and discussed, which can facilitate the improvement of the next generation cable-based transportation systems.},
  keywords  = {Payloads;Force;Drones;Control systems;Noise measurement;Dynamics;Cooperative Transportation;Force Estimate;Leader-Follower systems},
  issn      = {2378-5861},
  month     = {July}
}

