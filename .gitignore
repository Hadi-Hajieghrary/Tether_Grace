# --- Simulation output -------------------------------------------------
# The output/ tree is regenerated by campaign runners. Only READMEs and
# metric-summary files (publication_metrics.csv, summary_metrics.csv)
# are tracked; all raw trajectories, meshcat replays, and per-tick CSVs
# are ignored.
output/**
!output/**/README.md
!output/**/publication_metrics.csv
!output/**/summary_metrics.csv
!output/**/manifest.yaml

# --- Archive tree ------------------------------------------------------
# Small planning docs and source-code history are tracked; bulk prior
# simulation outputs are not.
archive/prior_campaigns/**
!archive/prior_campaigns/README.md
!archive/prior_campaigns/**/README.md
!archive/prior_campaigns/**/NOTES.txt
archive/partial_ablation_2026_04/runs/**
!archive/partial_ablation_2026_04/runs/README.md

# --- OS noise ----------------------------------------------------------
.DS_Store
Thumbs.db

# --- Misc user scratch -------------------------------------------------
*.tmp
*.local
